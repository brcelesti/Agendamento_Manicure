const SHEET_NAME = 'agendamentos';
const CONFIG_SHEET = 'config';

// ---- FUNÇÕES DE CONFIGURAÇÃO ----

function getConfig() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CONFIG_SHEET);
  const data = sheet.getDataRange().getValues();
  const config = {};
  data.forEach(row => { config[row[0]] = row[1]; });
  return config;
}

// ---- FUNÇÕES DE AGENDAMENTO ----

function gerarID() {
  return 'AG' + new Date().getTime();
}

function getAgendamentos() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_NAME);
  const data = sheet.getDataRange().getValues();
  const headers = data[0];
  return data.slice(1).map(row => {
    const obj = {};
    headers.forEach((h, i) => obj[h] = row[i]);
    return obj;
  });
}

function verificarDisponibilidade(data, horario) {
  const agendamentos = getAgendamentos();
  const conflito = agendamentos.find(a =>
    a['Data'] === data &&
    a['Horário'] === horario &&
    a['Status'] !== 'cancelado'
  );
  return !conflito; // true = disponível
}

function criarAgendamento(nome, whatsapp, servico, data, horario, obs) {
  if (!verificarDisponibilidade(data, horario)) {
    return { sucesso: false, mensagem: 'Horário já ocupado.' };
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_NAME);
  const id = gerarID();

  sheet.appendRow([id, nome, whatsapp, servico, data, horario, 'confirmado', obs || '']);

  return { sucesso: true, id, mensagem: `Agendamento ${id} criado com sucesso!` };
}

function cancelarAgendamento(id) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_NAME);
  const data = sheet.getDataRange().getValues();

  for (let i = 1; i < data.length; i++) {
    if (data[i][0] === id) {
      sheet.getRange(i + 1, 7).setValue('cancelado');
      return { sucesso: true, mensagem: 'Agendamento cancelado.' };
    }
  }
  return { sucesso: false, mensagem: 'Agendamento não encontrado.' };
}

function getHorariosDisponiveis(dataSelecionada) {
  const config = getConfig();
  const inicio = parseInt(config['horario_inicio'].split(':')[0]);
  const fim = parseInt(config['horario_fim'].split(':')[0]);
  const duracao = parseInt(config['duracao_padrao']);

  const slots = [];
  for (let h = inicio; h < fim; h += duracao / 60) {
    const hora = String(Math.floor(h)).padStart(2, '0') + ':00';
    if (verificarDisponibilidade(dataSelecionada, hora)) {
      slots.push(hora);
    }
  }
  return slots;
}

// ---- API WEB (para o site e o bot usarem) ----

function doGet(e) {
  const acao = e.parameter.acao;

  if (acao === 'horarios') {
    const data = e.parameter.data;
    const horarios = getHorariosDisponiveis(data);
    return responderJSON({ horarios });
  }

  if (acao === 'agendamentos') {
    const todos = getAgendamentos();
    return responderJSON({ agendamentos: todos });
  }

  return responderJSON({ erro: 'Ação não reconhecida' });
}

function doPost(e) {
  const body = JSON.parse(e.postData.contents);
  const acao = body.acao;

  if (acao === 'criar') {
    const resultado = criarAgendamento(
      body.nome, body.whatsapp, body.servico,
      body.data, body.horario, body.obs
    );
    return responderJSON(resultado);
  }

  if (acao === 'cancelar') {
    const resultado = cancelarAgendamento(body.id);
    return responderJSON(resultado);
  }

  return responderJSON({ erro: 'Ação não reconhecida' });
}

function responderJSON(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

// ---- LEMBRETE AUTOMÁTICO (rodar todo dia às 9h) ----

function enviarLembretes() {
  const amanha = new Date();
  amanha.setDate(amanha.getDate() + 1);
  const dataAmanha = Utilities.formatDate(amanha, 'America/Sao_Paulo', 'dd/MM/yyyy');

  const agendamentos = getAgendamentos();
  const deAmanha = agendamentos.filter(a =>
    a['Data'] === dataAmanha && a['Status'] === 'confirmado'
  );

  deAmanha.forEach(a => {
    Logger.log(`Lembrete para: ${a['Nome']} - ${a['Horário']} - WhatsApp: ${a['WhatsApp']}`);
    // Na Fase 4 você conecta o Twilio aqui para mandar a mensagem
  });
}
